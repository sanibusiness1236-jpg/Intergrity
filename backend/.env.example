# =============================================================================
# DATABASE  —  Supabase Postgres (hosted)
# =============================================================================
# Two URLs are required so Prisma can:
#   - run app queries through the pooler (PgBouncer, port 6543)
#   - run `prisma migrate` over a direct connection (port 5432)
# Get both from: Supabase Dashboard -> Project Settings -> Database -> Connection string
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DATABASE_URL_DIRECT="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# =============================================================================
# SUPABASE STORAGE  —  used for institution logo uploads
# =============================================================================
# Supabase Dashboard -> Project Settings -> API
#   SUPABASE_URL          : the "Project URL"  (e.g. https://<ref>.supabase.co)
#   SUPABASE_SERVICE_KEY  : the "service_role" key  (NOT the anon key)
# The bucket must exist and be public. Create it once in:
#   Supabase Dashboard -> Storage -> New bucket -> name "institution-logos" -> Public
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_KEY="eyJ..."
SUPABASE_LOGO_BUCKET="institution-logos"
# The "question-media" bucket is created automatically on first upload
# (no manual setup needed)

# =============================================================================
# REDIS  —  Upstash (hosted)
# =============================================================================
REDIS_URL="rediss://default:UPSTASH_PASSWORD@UPSTASH_HOST.upstash.io:6379"

# =============================================================================
# AUTH
# =============================================================================
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# =============================================================================
# CORS  —  comma-separated list of allowed origins, or "*" for any
# =============================================================================
# Production:  CORS_ORIGIN="https://your-frontend.vercel.app"
# Dev:         CORS_ORIGIN="*"
CORS_ORIGIN="*"

# =============================================================================
# SERVICES
# =============================================================================
# In production, point this at your Hugging Face Space URL:
#   https://YOUR-NAME-integrity-ml.hf.space
ML_SERVICE_URL="http://localhost:8000"
PORT=5000
NODE_ENV=development
# Public URL of this backend — used to self-ping /health every 10 min so
# the Render free tier never cold-starts.  Leave blank in local dev.
# In production set this to e.g. https://integrity-backend.onrender.com
PUBLIC_URL=""

# =============================================================================
# HUGGING FACE  —  required for AI Question Import feature
# =============================================================================
# Generate a "Read" token at: https://huggingface.co/settings/tokens
# Add this SAME variable (HF_TOKEN) as a secret in your HF Space settings.
HF_TOKEN="hf_..."

# =============================================================================
# PERFORMANCE / SCALING TUNING  (all optional — sensible defaults shown)
# =============================================================================
# Per-IP request ceilings (only enforced when NODE_ENV=production).
RATE_LIMIT_GLOBAL=600          # max requests / minute / IP across the whole API
RATE_LIMIT_AUTH=50             # max FAILED auth attempts / 15 min / IP
# How long (seconds) to cache a user's role/active status in Redis so most
# authenticated requests skip the DB. Lower = role changes apply faster.
AUTH_CACHE_TTL=30
# How long (ms) the examiner live-monitor result is cached/shared so many
# examiners polling the same exam collapse into one DB query.
LIVE_SESSIONS_CACHE_MS=4000
# Caps for AI question import so heavy uploads can't tie up resources.
EXTRACT_TIMEOUT_MS=120000      # max time for OCR/PDF/DOCX extraction
HF_TIMEOUT_MS=30000            # max time per Hugging Face inference call
# Log any request slower than this many ms (visibility under load).
SLOW_REQUEST_MS=800
