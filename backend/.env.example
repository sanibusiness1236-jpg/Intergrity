# =============================================================================
# DATABASE  —  Supabase Postgres (hosted)
# =============================================================================
# Two URLs are required so Prisma can:
#   - run app queries through the pooler (PgBouncer, port 6543)
#   - run `prisma migrate` over a direct connection (port 5432)
# Get both from: Supabase Dashboard -> Project Settings -> Database -> Connection string
#
# PROJECT_REF  = e.g. abcdefghijklmnop
# REGION       = e.g. eu-west-3  (pick the region you created the project in)
# PASSWORD     = the DB password you set when creating the project
#
# Local development against a local Postgres is still supported — just paste
# postgresql://postgres:password@localhost:5432/integrity into DATABASE_URL
# and leave DATABASE_URL_DIRECT unset (or equal to DATABASE_URL).
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DATABASE_URL_DIRECT="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# =============================================================================
# REDIS  —  Upstash (hosted, recommended) or local
# =============================================================================
# Upstash gives you a serverless-friendly Redis with a free tier.
# Dashboard: https://console.upstash.com -> Create Database -> copy the
# `rediss://` (TLS) connection string from the "Node / ioredis" tab.
#
# Local fallback: redis://localhost:6379
REDIS_URL="rediss://default:UPSTASH_PASSWORD@UPSTASH_HOST.upstash.io:6379"

# =============================================================================
# AUTH
# =============================================================================
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# =============================================================================
# SERVICES
# =============================================================================
ML_SERVICE_URL="http://localhost:8000"
PORT=5000
NODE_ENV=development
